{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@whatsapp-sender/database": ["../../packages/database/src/index.ts"],
      "@whatsapp-sender/contracts": ["../../packages/contracts/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
