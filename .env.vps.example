# ─────────────────────────────────────────────────────────────
# WhatsApp Sender — VPS production (arheb.net subdomains)
# Copy on server: cp .env.vps.example .env
# ─────────────────────────────────────────────────────────────

# Postgres (Docker service name "postgres", not localhost)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://whatsapp:CHANGE_ME_STRONG_PASSWORD@postgres:5432/whatsapp_sender

REDIS_URL=redis://redis:6379

API_PORT=3010
# Host ports on VPS (avoid conflict if 3010/3011 already used by another app)
API_HOST_PORT=3020
WEB_HOST_PORT=3021
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Public HTTPS URLs (Nginx + Certbot on srv851550)
CORS_ORIGIN=https://whatsapp.arheb.net
NEXT_PUBLIC_API_URL=https://api.whatsapp.arheb.net
NEXT_PUBLIC_WEB_URL=https://whatsapp.arheb.net

# Real WhatsApp pairing in production
BAILEYS_MOCK=0
WORKER_CONCURRENCY=5

WEBHOOK_SIGNING_SECRET=CHANGE_ME_WEBHOOK_SECRET
