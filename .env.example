# ─────────────────────────────────────────────────────────────
# WhatsApp Sender — environment template
# Copy: cp .env.example .env
# Local dev: bash scripts/setup-local.sh && bash scripts/dev.sh
# ─────────────────────────────────────────────────────────────

# Database
# Homebrew Postgres: localhost:5432
# Docker Compose:    localhost:5433 (see docker-compose.yml)
DATABASE_URL=postgresql://whatsapp:whatsapp@localhost:5432/whatsapp_sender

# Redis
# Homebrew: 6379 | Docker Compose: 6380
REDIS_URL=redis://localhost:6379

# API (NestJS)
API_PORT=3010
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3011

# Worker (Baileys + BullMQ)
# BAILEYS_MOCK=0 → real WhatsApp QR scan (production & normal dev)
# BAILEYS_MOCK=1 → demo mode only (auto-connect, no real scan — for CI/E2E)
BAILEYS_MOCK=0
WORKER_CONCURRENCY=5

# Session persistence (worker health loop + reconnect)
# How often the worker checks live socket health (ms)
SESSION_HEALTH_INTERVAL_MS=30000
# Mark DB disconnected only when CONNECTED with no auth files and no heartbeat this long (ms)
SESSION_STALE_THRESHOLD_MS=600000
# After worker boot, skip stale-disconnect for this long while sessions restore (ms)
SESSION_HEALTH_STARTUP_GRACE_MS=300000
# Max delay between reconnect attempts after transient disconnect (ms)
SESSION_RECONNECT_MAX_DELAY_MS=60000

# Web (Next.js) — baked in at build time for production
NEXT_PUBLIC_API_URL=http://localhost:3010
NEXT_PUBLIC_WEB_URL=http://localhost:3011

# Webhooks
WEBHOOK_SIGNING_SECRET=change-me-webhook-secret

# Admin WhatsApp alerts + OTP delivery (platform session must stay connected)
ADMIN_PHONE=201277785111
ADMIN_NOTIFY_ENABLED=1
ADMIN_NOTIFY_SESSION_ID=
OTP_SESSION_ID=
OTP_DEV_MODE=0
