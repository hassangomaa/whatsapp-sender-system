# Database (Homebrew: 5432, Docker Compose: 5433)
DATABASE_URL=postgresql://whatsapp:whatsapp@localhost:5432/whatsapp_sender

# Redis (Homebrew: 6379, Docker Compose: 6380)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3010
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3011

# Worker
WORKER_CONCURRENCY=5
BAILEYS_MOCK=0

# Web
NEXT_PUBLIC_API_URL=http://localhost:3010

# Webhooks
WEBHOOK_SIGNING_SECRET=change-me-webhook-secret
